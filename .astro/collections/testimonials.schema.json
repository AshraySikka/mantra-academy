{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "author": {
      "type": "string"
    },
    "rating": {
      "default": 5,
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "author",
    "date"
  ]
}