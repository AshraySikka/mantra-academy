---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Admissions & Contact"
  description="Book a free demo class or get in touch with Mantra Academy in Indirapuram, Ghaziabad. WhatsApp, email, and inquiry form available."
  path="/admissions"
>
  <section class="section">
    <div class="container admissions-grid">
      <div>
        <p class="eyebrow">Admissions</p>
        <h1>Let's get your child started.</h1>
        <p class="lede">
          Fill out the form, message us on WhatsApp, or email us, whichever
          is easiest for you. We'll get back with demo class timings.
        </p>

        <div class="contact-block card">
          <h2>Contact details</h2>
          <p>
            <strong>Address</strong><br />
            <a href="https://maps.app.goo.gl/ycRjhyuQ9EoyVZvEA" target="_blank" rel="noopener noreferrer">
              Ground Floor, Plot No. 199, Shakti Khand III,<br />
              Indirapuram, Ghaziabad, Uttar Pradesh 201010
            </a>
          </p>
          <p>
            <strong>WhatsApp / Phone</strong><br />
            <a href="https://wa.me/919324688372" target="_blank" rel="noopener noreferrer">+91 93246 88372</a>
          </p>
          <p>
            <strong>Email</strong><br />
            <a href="mailto:learnwithusatmantra@gmail.com">learnwithusatmantra@gmail.com</a>
          </p>
          <div class="contact-block__follow">
            <strong>Follow us</strong>
            <p class="contact-block__icons">
              <a href="https://www.instagram.com/learnwithmantra" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1"/></svg>
              </a>
              <a href="https://www.facebook.com/share/1CpeZgonLD/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.5.3v2.7h-1.4c-1.4 0-1.8.8-1.8 1.7V12h3l-.5 2.9h-2.5v7A10 10 0 0 0 22 12Z"/></svg>
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="form-wrap card">
        <h2>Inquiry form</h2>
        <p class="form-wrap__hint">Fill this out and we'll get back to you with demo class timings.</p>
        <iframe
          id="mantra-inquiry-frame"
          title="Mantra Academy Admissions Inquiry Form"
          src="https://form.jotform.com/260290916550254"
          style="width:100%; border:none;"
        ></iframe>
      </div>
    </div>
  </section>

  <script src="https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js" is:inline></script>
  <script is:inline>
    if (window.jotformEmbedHandler) {
      window.jotformEmbedHandler("iframe#mantra-inquiry-frame", "https://form.jotform.com/");
    }
  </script>
</Layout>

<style>
  .lede { font-size: var(--step-1); max-width: 55ch; margin-bottom: var(--space-3); }
  .admissions-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .contact-block { margin-top: var(--space-3); }
  .contact-block p { margin-bottom: var(--space-2); }
  .contact-block a { text-decoration: underline; text-decoration-color: rgba(27,58,99,0.3); }
  .contact-block__follow { margin-top: var(--space-2); }
  .contact-block__icons { display: flex; gap: 0.6em; margin-top: 0.4em; }
  .contact-block__icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(27,58,99,0.08);
    color: var(--color-navy);
    text-decoration: none;
  }
  .contact-block__icons a:hover { background: var(--color-mustard); color: var(--color-navy-deep); }
  .form-wrap__hint { color: var(--color-charcoal); margin-bottom: var(--space-2); }
  .form-wrap iframe { min-height: 1100px; }
  @media (max-width: 900px) {
    .admissions-grid { grid-template-columns: 1fr; }
  }
</style>