---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notices = (await getCollection('notices')).sort((a, b) => {
  if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---

<Layout
  title="Updates & Noticeboard"
  description="Latest updates, notices, and announcements from Mantra Academy."
  path="/updates"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Noticeboard</p>
      <h1>Updates</h1>
      <p class="lede">The latest news, class updates, and announcements from Mantra Academy.</p>

      <div class="notice-list">
        {notices.length === 0 && (
          <p>No updates posted yet. Check back soon.</p>
        )}
        {notices.map((notice) => (
          <article class="notice-card card">
            {notice.data.pinned && <span class="notice-pin">Pinned</span>}
            <h2>{notice.data.title}</h2>
            <p class="notice-date">
              {notice.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <p>{notice.data.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .lede { font-size: var(--step-1); max-width: 60ch; margin-bottom: var(--space-4); }
  .notice-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .notice-card { position: relative; }
  .notice-pin {
    position: absolute;
    top: var(--space-3); right: var(--space-3);
    background: var(--color-mustard);
    color: var(--color-navy-deep);
    font-weight: 700;
    font-size: var(--step--1);
    padding: 0.3em 0.8em;
    border-radius: 999px;
  }
  .notice-date { color: var(--color-mustard); font-weight: 600; font-size: var(--step--1); }
</style>
