---
import Layout from '../layouts/Layout.astro';

const scienceResults = [
  { name: "Srishti", score: 99, img: "sci-srishti" },
  { name: "Harshil", score: 98, img: "sci-harshil" },
  { name: "Danish", score: 98, img: "sci-danish" },
  { name: "Vishu", score: 98, img: "sci-vishu" },
  { name: "Prashant", score: 98, img: "sci-prashant" },
  { name: "Tanuj", score: 98, img: "sci-tanuj" },
  { name: "Sanidhya", score: 97, img: "sci-sanidhya" },
  { name: "Ayush", score: 97, img: "sci-ayush" },
  { name: "Viraz", score: 97, img: "sci-viraz" },
  { name: "Hanita", score: 97, img: "sci-hanita" },
  { name: "Avika", score: 97, img: "sci-avika" },
  { name: "Priyanshi", score: 95, img: "sci-priyanshi" },
  { name: "Mihika", score: 95, img: "sci-mihika" },
  { name: "Vaidahi", score: 95, img: "sci-vaidahi" },
  { name: "Sarthak", score: 95, img: "sci-sarthak" },
  { name: "Neel", score: 95, note: "Crash Course", img: "sci-neel" },
  { name: "Pratham", score: 94, img: "sci-pratham" },
  { name: "Jayani", score: 94, img: "sci-jayani" },
  { name: "Vanshika", score: 94, img: "sci-vanshika" },
  { name: "Dev", score: 94, img: "sci-dev" },
  { name: "Tanishqa", score: 93, img: "sci-tanishqa" },
  { name: "Devit", score: 93, img: "sci-devit" },
  { name: "Hitarth", score: 93, img: "sci-hitarth" },
  { name: "Aayush", score: 93, img: "sci-aayush2" },
  { name: "Shubhangi", score: 93, img: "sci-shubhangi" },
  { name: "Prachi", score: 93, img: "sci-prachi" },
  { name: "Aaryabrata", score: 92, img: "sci-aaryabrata" },
  { name: "Ishaan", score: 92, img: "sci-ishaan" },
  { name: "Akshara", score: 92, img: "sci-akshara" },
  { name: "Khush", score: 92, img: "sci-khush" },
  { name: "Dhruvi", score: 92, img: "sci-dhruvi" },
  { name: "Bharg", score: 91, img: "sci-bharg" },
  { name: "Yug", score: 91, img: "sci-yug" },
  { name: "Dwiti", score: 91, img: "sci-dwiti" },
  { name: "Mitra", score: 91, img: "sci-mitra" },
  { name: "Dhara", score: 90, img: "sci-dhara" },
];

const mathsScienceResults = [
  { name: "Harshil", score: 98, img: "ms-harshil" },
  { name: "Sanidhya", score: 96.5, img: "ms-sanidhya" },
  { name: "Danish", score: 96.5, img: "ms-danish" },
  { name: "Viraz", score: 96, img: "ms-viraz" },
  { name: "Ayush", score: 96, img: "ms-ayush" },
  { name: "Srishti", score: 96, img: "ms-srishti" },
  { name: "Vishu", score: 95, img: "ms-vishu" },
  { name: "Priyanshi", score: 94.5, img: "ms-priyanshi" },
  { name: "Tanishqa", score: 94, img: "ms-tanishqa" },
  { name: "Pranshant", score: 93.5, img: "ms-pranshant" },
  { name: "Devit", score: 93.5, img: "ms-devit" },
  { name: "Pratham", score: 93.5, img: "ms-pratham" },
  { name: "Mihika", score: 93, img: "ms-mihika" },
  { name: "Aaryabrata", score: 93, img: "ms-aaryabrata" },
  { name: "Bharg", score: 93, note: "Crash Course", img: "ms-bharg" },
  { name: "Jayani", score: 91, img: "ms-jayani" },
  { name: "Tanuj", score: 90.5, img: "ms-tanuj" },
  { name: "Hanita", score: 90.5, img: "ms-hanita" },
  { name: "Hitarth", score: 90.5, img: "ms-hitarth" },
];

const allScores = [...scienceResults, ...mathsScienceResults].map(r => r.score);
const avg = (allScores.reduce((a, b) => a + b, 0) / allScores.length).toFixed(1);
const above90 = allScores.filter(s => s >= 90).length;
const pctAbove90 = Math.round((above90 / allScores.length) * 100);
const top = Math.max(...allScores);
---

<Layout
  title="Results"
  description="Real board exam results achieved through Mantra Academy's teaching approach."
  path="/results"
>
  <section class="results-hero">
    <div class="container">
      <p class="eyebrow" style="display:flex; justify-content:center;">X-Board Results</p>
      <h1>Numbers students actually walked in with.</h1>
      <p class="subhead">
        Real board scores from students taught using the same teaching approach now used at Mantra Academy.
        <span class="disclosure">Results shown were achieved while teaching at ThinkGurus, prior to founding Mantra Academy.</span>
      </p>

      <div class="summary-stats">
        <div class="card stat-card">
          <span class="stat-num">{avg}%</span>
          <span class="stat-label">Average Score</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num">{pctAbove90}%</span>
          <span class="stat-label">Students Scoring 90%+</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num">{top}%</span>
          <span class="stat-label">Top Score</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num">{allScores.length}</span>
          <span class="stat-label">Students Shown</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Science</h2>
      <div class="filter-bar">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="95">95+</button>
        <button class="filter-btn" data-filter="90">90+</button>
      </div>
      <div class="card-grid" id="science-grid">
        {scienceResults.map((r) => (
          <div class="result-card" data-score={r.score}>
            <img class="avatar-photo" src={`/images/results/${r.img}.jpg`} alt={r.name} width="80" height="80" loading="lazy" />
            <p class="r-name">{r.name}</p>
            <p class="r-score">{r.score}%</p>
            {r.note && <p class="r-note">{r.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <h2 class="section-title">Maths &amp; Science Combined</h2>
      <div class="card-grid">
        {mathsScienceResults.map((r) => (
          <div class="result-card" data-score={r.score}>
            <img class="avatar-photo" src={`/images/results/${r.img}.jpg`} alt={r.name} width="80" height="80" loading="lazy" />
            <p class="r-name">{r.name}</p>
            <p class="r-score">{r.score}%</p>
            {r.note && <p class="r-note">{r.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--navy" style="text-align:center;">
    <div class="container">
      <h2>Want results like these for your child?</h2>
      <a href="/admissions" class="btn btn--primary">Book a Free Demo Class</a>
    </div>
  </section>
</Layout>

<style>
  .results-hero { padding: var(--space-5) 0 var(--space-4); text-align: center; }
  .results-hero h1 { margin-top: 0.3em; }
  .subhead { max-width: 65ch; margin: 0 auto; font-size: var(--step-0); }
  .disclosure {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--step--1);
    color: rgba(34,34,34,0.6);
    font-style: italic;
  }

  .summary-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
    margin-top: var(--space-4);
  }
  .stat-card { text-align: center; padding: var(--space-3) var(--space-2); }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 800;
    color: var(--color-navy);
  }
  .stat-label { font-size: var(--step--1); color: var(--color-charcoal); }

  .section-title { text-align: center; margin-bottom: var(--space-3); }

  .filter-bar { display: flex; justify-content: center; gap: 0.5em; margin-bottom: var(--space-3); }
  .filter-btn {
    border: 1.5px solid rgba(27,58,99,0.25);
    background: var(--color-white);
    border-radius: 999px;
    padding: 0.4em 1.2em;
    font-size: var(--step--1);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-btn.active, .filter-btn:hover {
    background: var(--color-navy);
    color: var(--color-white);
    border-color: var(--color-navy);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: var(--space-2);
  }
  .result-card {
    background: var(--color-card);
    border: 1px solid rgba(27,58,99,0.08);
    border-radius: var(--radius);
    padding: var(--space-2);
    text-align: center;
    box-shadow: 0 6px 16px -10px rgba(27,58,99,0.18);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .result-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px -10px rgba(27,58,99,0.3); }
  .result-card.hidden { display: none; }

  .avatar-photo {
    width: 64px; height: 64px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 0.4em;
    display: block;
    border: 2px solid var(--color-mustard);
  }
  .r-name { font-weight: 600; font-size: var(--step--1); margin-bottom: 2px; color: var(--color-navy); }
  .r-score { color: var(--color-mustard); font-weight: 800; font-size: var(--step-0); margin: 0; }
  .r-note { font-size: 0.7rem; color: rgba(34,34,34,0.5); margin-top: 2px; }

  @media (max-width: 700px) {
    .summary-stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll("#science-grid .result-card");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      buttons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      const filter = btn.getAttribute("data-filter");
      cards.forEach((card) => {
        const score = parseFloat(card.getAttribute("data-score") || "0");
        if (filter === "all" || score >= parseFloat(filter)) card.classList.remove("hidden");
        else card.classList.add("hidden");
      });
    });
  });
</script>