---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const seo = await getEntry('seo', 'results');

const scienceResults = [
  { name: "Srishti", score: 99 }, { name: "Harshil", score: 98 }, { name: "Danish", score: 98 },
  { name: "Vishu", score: 98 }, { name: "Prashant", score: 98 }, { name: "Tanuj", score: 98 },
  { name: "Sanidhya", score: 97 }, { name: "Ayush", score: 97 }, { name: "Viraz", score: 97 },
  { name: "Hanita", score: 97 }, { name: "Avika", score: 97 }, { name: "Priyanshi", score: 95 },
  { name: "Mihika", score: 95 }, { name: "Vaidahi", score: 95 }, { name: "Sarthak", score: 95 },
  { name: "Neel", score: 95, note: "Crash Course" }, { name: "Pratham", score: 94 },
  { name: "Jayani", score: 94 }, { name: "Vanshika", score: 94 }, { name: "Dev", score: 94 },
  { name: "Tanishqa", score: 93 }, { name: "Devit", score: 93 }, { name: "Hitarth", score: 93 },
  { name: "Aayush", score: 93 }, { name: "Shubhangi", score: 93 }, { name: "Prachi", score: 93 },
  { name: "Aaryabrata", score: 92 }, { name: "Ishaan", score: 92 }, { name: "Akshara", score: 92 },
  { name: "Khush", score: 92 }, { name: "Dhruvi", score: 92 }, { name: "Bharg", score: 91 },
  { name: "Yug", score: 91 }, { name: "Dwiti", score: 91 }, { name: "Mitra", score: 91 },
  { name: "Dhara", score: 90 },
];

const mathsScienceResults = [
  { name: "Harshil", score: 98 }, { name: "Sanidhya", score: 96.5 }, { name: "Danish", score: 96.5 },
  { name: "Viraz", score: 96 }, { name: "Ayush", score: 96 }, { name: "Srishti", score: 96 },
  { name: "Vishu", score: 95 }, { name: "Priyanshi", score: 94.5 }, { name: "Tanishqa", score: 94 },
  { name: "Pranshant", score: 93.5 }, { name: "Devit", score: 93.5 }, { name: "Pratham", score: 93.5 },
  { name: "Mihika", score: 93 }, { name: "Aaryabrata", score: 93 },
  { name: "Bharg", score: 93, note: "Crash Course" }, { name: "Jayani", score: 91 },
  { name: "Tanuj", score: 90.5 }, { name: "Hanita", score: 90.5 }, { name: "Hitarth", score: 90.5 },
];

const allScores = [...scienceResults, ...mathsScienceResults].map(r => r.score);
const avg = (allScores.reduce((a, b) => a + b, 0) / allScores.length).toFixed(1);
const above90 = allScores.filter(s => s >= 90).length;
const pctAbove90 = Math.round((above90 / allScores.length) * 100);
const top = Math.max(...allScores);
---

<Layout
  title={seo?.data.title ?? "Results"}
  description={seo?.data.description ?? "Real board exam results achieved through Mantra Academy's teaching approach."}
  path="/results"
  ogImage={seo?.data.ogImage}
  canonicalOverride={seo?.data.canonicalOverride}
  extraSchemaJson={seo?.data.schemaJson}
>
  <section class="results-hero">
    <div class="container">
      <p class="eyebrow" style="display:flex; justify-content:center;">Proven Results</p>
      <h1>Founder's Academic Track Record</h1>
      <p class="subhead">
        Before establishing Mantra Academy, our founder helped students achieve outstanding academic results through personalized guidance, strong fundamentals, and a structured learning approach. The achievements below reflect the experience and teaching philosophy that continue to shape every program at Mantra Academy.
        <span class="disclosure">Results shown are from students personally taught by our founder prior to the establishment of Mantra Academy. Individual student outcomes vary based on factors such as effort, attendance, and engagement.</span>
      </p>

      <div class="summary-stats">
        <div class="card stat-card">
          <span class="stat-num">{avg}%</span>
          <span class="stat-label">Average Score</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num">55</span>
          <span class="stat-label">Students Scored 90%+</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num">{top}%</span>
          <span class="stat-label">Top Score</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num">2025</span>
          <span class="stat-label">Results Aggregate</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .results-hero { padding: var(--space-5) 0 var(--space-4); text-align: center; }
  .results-hero h1 { margin-top: 0.3em; }
  .subhead { max-width: 65ch; margin: 0 auto; font-size: var(--step-0); }
  .disclosure {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--step--1);
    color: rgba(34,34,34,0.6);
    font-style: italic;
  }

  .summary-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
    margin-top: var(--space-4);
  }
  .stat-card { text-align: center; padding: var(--space-3) var(--space-2); }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 800;
    color: var(--color-navy);
  }
  .stat-label { font-size: var(--step--1); color: var(--color-charcoal); }

  .section-title { text-align: center; margin-bottom: var(--space-3); }

  .filter-bar { display: flex; justify-content: center; gap: 0.5em; margin-bottom: var(--space-3); }
  .filter-btn {
    border: 1.5px solid rgba(27,58,99,0.25);
    background: var(--color-white);
    border-radius: 999px;
    padding: 0.4em 1.2em;
    font-size: var(--step--1);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-btn.active, .filter-btn:hover {
    background: var(--color-navy);
    color: var(--color-white);
    border-color: var(--color-navy);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: var(--space-2);
  }
  .result-card {
    background: var(--color-card);
    border: 1px solid rgba(27,58,99,0.08);
    border-radius: var(--radius);
    padding: var(--space-2);
    text-align: center;
    box-shadow: 0 6px 16px -10px rgba(27,58,99,0.18);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .result-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px -10px rgba(27,58,99,0.3); }
  .result-card.hidden { display: none; }

  .avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-deep));
    color: var(--color-white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-1);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 0.4em;
  }
  .r-name { font-weight: 600; font-size: var(--step--1); margin-bottom: 2px; color: var(--color-navy); }
  .r-score { color: var(--color-mustard); font-weight: 800; font-size: var(--step-0); margin: 0; }
  .r-note { font-size: 0.7rem; color: rgba(34,34,34,0.5); margin-top: 2px; }

  @media (max-width: 700px) {
    .summary-stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll("#science-grid .result-card");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      buttons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      const filter = btn.getAttribute("data-filter");
      cards.forEach((card) => {
        const score = parseFloat(card.getAttribute("data-score") || "0");
        if (filter === "all" || score >= parseFloat(filter)) card.classList.remove("hidden");
        else card.classList.add("hidden");
      });
    });
  });
</script>