---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTestimonials = (await getCollection('testimonials')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const avgRating = allTestimonials.length
  ? allTestimonials.reduce((sum, t) => sum + t.data.rating, 0) / allTestimonials.length
  : null;

function initials(name: string) {
  return name
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase())
    .join('');
}

function stars(rating: number) {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<Layout
  title="Reviews & Testimonials"
  description="Read what parents and students say about Mantra Academy's Maths and Science tuition in Indirapuram, Ghaziabad."
  path="/testimonials"
>
  <section class="section reviews-hero">
    <div class="container">
      <p class="eyebrow">Reviews</p>
      <h1>What parents &amp; students say</h1>
      {avgRating && (
        <p class="avg-rating">
          <span class="avg-rating__stars" aria-hidden="true">{stars(Math.round(avgRating))}</span>
          <strong>{avgRating.toFixed(1)}</strong> average from {allTestimonials.length} reviews
        </p>
      )}
    </div>
  </section>

  <section class="section section--cream-warm">
    <div class="container">
      <div class="review-masonry">
        {allTestimonials.map((t) => (
          <div class="review-card">
            <span class="review-card__quote" aria-hidden="true">&ldquo;</span>
            <p class="review-card__stars" aria-label={`${t.data.rating} out of 5 stars`}>
              {stars(t.data.rating)}
            </p>
            <blockquote>{t.body?.trim()}</blockquote>
            <div class="review-card__footer">
              <span class="review-card__avatar" aria-hidden="true">{initials(t.data.author)}</span>
              <span class="review-card__author">{t.data.author}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .reviews-hero { padding-bottom: var(--space-3); }
  .avg-rating {
    display: flex;
    align-items: center;
    gap: 0.6em;
    font-size: var(--step-1);
    color: var(--color-charcoal);
  }
  .avg-rating__stars { color: var(--color-mustard); font-size: 1.2em; letter-spacing: 0.05em; }
  .avg-rating strong { color: var(--color-navy); }

  .review-masonry {
    column-count: 3;
    column-gap: var(--space-3);
  }
  .review-card {
    background: var(--color-white);
    border-radius: var(--radius);
    padding: var(--space-3) var(--space-3) var(--space-2);
    margin-bottom: var(--space-3);
    break-inside: avoid;
    display: inline-block;
    width: 100%;
    box-shadow: 0 10px 24px -16px rgba(27,58,99,0.22);
    position: relative;
  }
  .review-card__quote {
    position: absolute;
    top: 0.1em;
    right: 0.5em;
    font-family: var(--font-display);
    font-size: 3.2rem;
    color: var(--color-cream-warm);
    line-height: 1;
    z-index: 0;
  }
  .review-card__stars {
    color: var(--color-mustard);
    font-size: var(--step-0);
    letter-spacing: 0.08em;
    margin: 0 0 0.5em;
    position: relative;
    z-index: 1;
  }
  .review-card blockquote {
    margin: 0 0 var(--space-2);
    font-size: var(--step-0);
    color: var(--color-charcoal);
    line-height: 1.55;
    position: relative;
    z-index: 1;
  }
  .review-card__footer {
    display: flex;
    align-items: center;
    gap: 0.6em;
  }
  .review-card__avatar {
    width: 2.1em;
    height: 2.1em;
    flex: none;
    border-radius: 50%;
    background: var(--color-navy);
    color: var(--color-white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step--1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .review-card__author { color: var(--color-navy); font-weight: 700; }

  @media (max-width: 900px) {
    .review-masonry { column-count: 2; }
  }
  @media (max-width: 600px) {
    .review-masonry { column-count: 1; }
  }
</style>