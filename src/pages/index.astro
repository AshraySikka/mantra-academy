---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTestimonials = await getCollection('testimonials');
const featured = allTestimonials
  .filter((t) => t.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const avgRating = allTestimonials.length
  ? (allTestimonials.reduce((sum, t) => sum + t.data.rating, 0) / allTestimonials.length).toFixed(1)
  : null;

function stars(rating: number) {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<Layout
  title="Maths & Science Tuition for Grades 7–10 in Indirapuram, Ghaziabad"
  description="Mantra Academy offers CBSE and ICSE Maths, Science, SST and English tuition for Grades 7 to 10 in Indirapuram, Ghaziabad. Strong foundations, step-by-step guidance. Book a free demo class."
  path="/"
>
  <section class="hero">
    <div class="hero__bg">
      <img src="/images/hero-team.jpg" alt="" />
      <div class="hero__fade"></div>
    </div>
    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">💡 CBSE &amp; ICSE · Grades 7–10</p>
        <h1>Strong foundations.<br />Not a rushed syllabus.</h1>
        <p class="hero__lede">
          Mantra Academy teaches Maths, Science, SST, and English the way they
          should be taught: step by step, with concept clarity, so students build
          a real foundation instead of just keeping pace with the syllabus.
        </p>
        <div class="hero__actions">
          <a class="btn btn--primary" href="/admissions">Book a Free Demo Class</a>
          <a class="btn btn--outline-navy" href="/courses">See Courses</a>
        </div>
        <div class="hero__stat-row">
          <div class="hero__stat">
            <span class="hero__stat-num">17+</span>
            <span class="hero__stat-label">Years of<br />Teaching Experience</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-num">500+</span>
            <span class="hero__stat-label">Students<br />Mentored</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-num">4.9★</span>
            <span class="hero__stat-label">Average Parent<br />Rating</span>
          </div>
        </div>
        <p class="hero__trust">Trusted by parents. Loved by students.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Why us</p>
      <h2>We don't rush through the syllabus.</h2>
      <p class="section__lede">
        At Mantra Academy, we focus on building strong foundations and guiding
        students step-by-step toward improvement, not racing to finish chapters.
      </p>
      <div class="why-grid">
        <div class="card">
          <h3>Concept clarity first</h3>
          <p>Every topic is taught to be understood, not memorized, so it sticks well beyond the exam.</p>
        </div>
        <div class="card">
          <h3>Both boards covered</h3>
          <p>Dedicated guidance for CBSE and ICSE students, with curriculum-specific attention where it matters.</p>
        </div>
        <div class="card">
          <h3>Step-by-step progress</h3>
          <p>We track where each student is, and build forward from there, rather than a one-size-fits-all pace.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container">
      <div class="testimonial-heading">
        <p class="eyebrow">★★★★★ What parents &amp; students say</p>
        <h2>Real reviews from real families.</h2>
      </div>
      <div class="testimonial-grid">
        {featured.map((t) => (
          <div class="testimonial-card">
            <p class="testimonial-card__stars" aria-label={`${t.data.rating} out of 5 stars`}>
              {stars(t.data.rating)}
            </p>
            <blockquote>{t.body?.trim()}</blockquote>
            <p class="testimonial-card__author">— {t.data.author}</p>
          </div>
        ))}
      </div>
      <p class="testimonial-cta">
        <a class="btn btn--outline" href="/testimonials">Read all reviews</a>
      </p>
    </div>
  </section>

  <section class="section section--cream-warm cta-band">
    <div class="container cta-band__inner">
      <div>
        <h2>Ready to see how we teach?</h2>
        <p>Book a free online demo class. No commitment, just a chance to see if we're the right fit.</p>
      </div>
      <a class="btn btn--primary" href="/admissions">Book Free Demo Class</a>
    </div>
  </section>
</Layout>

<style>
  /* --- Hero Section --- */
  .hero { 
    position: relative; 
    padding: var(--space-6) 0 var(--space-5); 
    overflow: hidden; 
    min-height: 600px; 
    display: flex; 
    align-items: center; 
  }
  .hero__bg { 
    position: absolute; 
    inset: 0; 
    z-index: 0; 
  }
  .hero__bg img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    object-position: center 25%; 
  }
  .hero__fade {
    position: absolute; 
    inset: 0;
    background: linear-gradient(90deg,
      var(--color-cream) 0%,
      var(--color-cream) 38%,
      rgba(248,243,227,0.85) 50%,
      rgba(248,243,227,0.15) 68%,
      rgba(248,243,227,0) 80%
    );
  }
  .hero__inner { position: relative; z-index: 1; }
  .hero__copy { max-width: 580px; }
  .hero__lede { font-size: var(--step-1); color: var(--color-charcoal); max-width: 46ch; }
  .hero__actions { display: flex; gap: var(--space-2); margin-top: var(--space-3); flex-wrap: wrap; }
  
  .hero__stat-row {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-4);
    background: var(--color-card);
    border: 1px solid rgba(27,58,99,0.1);
    border-radius: var(--radius);
    padding: var(--space-3) var(--space-4);
    width: fit-content;
  }
  .hero__stat { display: flex; flex-direction: column; }
  .hero__stat-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-2);
    color: var(--color-navy);
    line-height: 1.1;
  }
  .hero__stat-label { font-size: var(--step--1); color: var(--color-charcoal); line-height: 1.3; }
  
  .hero__trust {
    margin-top: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-weight: 700;
    color: var(--color-navy);
    font-size: var(--step--1);
    background: rgba(217,165,33,0.15);
    border: 1px solid rgba(217,165,33,0.4);
    padding: 0.5em 1.1em;
    border-radius: 999px;
  }
  .hero__trust::before {
    content: "";
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-mustard);
    flex: none;
  }

  @media (max-width: 900px) {
    .hero { min-height: 0; padding: var(--space-4) 0 var(--space-4); }
    .hero__bg { position: relative; inset: auto; height: 280px; margin: 0 calc(-1 * var(--space-3)) var(--space-3); }
    .hero__fade { background: linear-gradient(180deg, rgba(248,243,227,0) 60%, var(--color-cream) 100%); }
    .hero__copy { max-width: 100%; }
    .hero__stat-row { flex-wrap: wrap; gap: var(--space-2); width: 100%; }
  }

  /* --- Other Sections --- */
  .section__lede { max-width: 60ch; font-size: var(--step-1); margin-bottom: var(--space-4); }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .testimonial-heading { text-align: center; }
  .testimonial-heading .eyebrow {
    display: flex;
    width: 100%;
    justify-content: center;
  }
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius);
    padding: var(--space-3);
  }
  .testimonial-card__stars { color: var(--color-mustard-light); margin-bottom: 0.5em; font-size: var(--step--1); }
  .testimonial-card blockquote {
    margin: 0 0 0.6em;
    font-size: var(--step-0);
    color: var(--color-white);
    font-family: var(--font-body);
    font-weight: 400;
  }
  .testimonial-card__author { color: var(--color-mustard-light); font-weight: 700; margin: 0; }
  .testimonial-cta { text-align: center; margin-top: var(--space-4); }

  .cta-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* --- Global Mobile Overrides --- */
  @media (max-width: 900px) {
    .why-grid { grid-template-columns: 1fr; }
    .testimonial-grid { grid-template-columns: 1fr 1fr; }
  }
  
  @media (max-width: 640px) {
    .testimonial-grid { grid-template-columns: 1fr; }
  }
</style>