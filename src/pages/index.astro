---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTestimonials = await getCollection('testimonials');
const featured = allTestimonials
  .filter((t) => t.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const avgRating = allTestimonials.length
  ? (allTestimonials.reduce((sum, t) => sum + t.data.rating, 0) / allTestimonials.length).toFixed(1)
  : null;

function stars(rating: number) {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<Layout
  title="Maths & Science Tuition for Grades 7–10 in Indirapuram, Ghaziabad"
  description="Mantra Academy offers CBSE and ICSE Maths and Science tuition for Grades 7 to 10 in Indirapuram, Ghaziabad. Strong foundations, step-by-step guidance. Book a free demo class."
  path="/"
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">💡 CBSE &amp; ICSE · Grades 7–10</p>
        <h1>Strong foundations.<br />Not a rushed syllabus.</h1>
        <p class="hero__lede">
          Mantra Academy teaches Maths and Science the way it should be taught:
          step by step, with concept clarity, so students build a real foundation
          instead of just keeping pace with the syllabus.
        </p>
        <div class="hero__actions">
          <a class="btn btn--primary" href="/admissions">Book a Free Demo Class</a>
          <a class="btn btn--outline-navy" href="/courses">See Courses</a>
        </div>
      </div>
      <div class="hero__art" aria-hidden="true">
        <div class="stat-cluster">
          <div class="stat-chip stat-chip--a">
            <span class="stat-chip__num">80+</span>
            <span class="stat-chip__label">Students taught yearly</span>
          </div>
          <div class="stat-chip stat-chip--b">
            <span class="stat-chip__num">{avgRating ?? '5.0'}★</span>
            <span class="stat-chip__label">Average parent rating</span>
          </div>
          <div class="stat-chip stat-chip--c">
            <span class="stat-chip__num">17+</span>
            <span class="stat-chip__label">Years teaching</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Why us</p>
      <h2>We don't rush through the syllabus.</h2>
      <p class="section__lede">
        At Mantra Academy, we focus on building strong foundations and guiding
        students step-by-step toward improvement, not racing to finish chapters.
      </p>
      <div class="why-grid">
        <div class="card">
          <h3>Concept clarity first</h3>
          <p>Every topic is taught to be understood, not memorized, so it sticks well beyond the exam.</p>
        </div>
        <div class="card">
          <h3>Both boards covered</h3>
          <p>Dedicated guidance for CBSE and ICSE students, with curriculum-specific attention where it matters.</p>
        </div>
        <div class="card">
          <h3>Step-by-step progress</h3>
          <p>We track where each student is, and build forward from there, rather than a one-size-fits-all pace.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container">
      <div class="testimonial-heading">
        <p class="eyebrow">★★★★★ What parents &amp; students say</p>
        <h2>Real reviews from real families.</h2>
      </div>
      <div class="testimonial-grid">
        {featured.map((t) => (
          <div class="testimonial-card">
            <p class="testimonial-card__stars" aria-label={`${t.data.rating} out of 5 stars`}>
              {stars(t.data.rating)}
            </p>
            <blockquote>{t.body?.trim()}</blockquote>
            <p class="testimonial-card__author">— {t.data.author}</p>
          </div>
        ))}
      </div>
      <p class="testimonial-cta">
        <a class="btn btn--outline" href="/testimonials">Read all reviews</a>
      </p>
    </div>
  </section>

  <section class="section section--cream-warm cta-band">
    <div class="container cta-band__inner">
      <div>
        <h2>Ready to see how we teach?</h2>
        <p>Book a free online demo class. No commitment, just a chance to see if we're the right fit.</p>
      </div>
      <a class="btn btn--primary" href="/admissions">Book Free Demo Class</a>
    </div>
  </section>
</Layout>

<style>
  .hero { padding: var(--space-6) 0 var(--space-5); background: var(--color-cream); }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.3fr 0.8fr;
    gap: var(--space-4);
    align-items: center;
  }
  .hero__lede { font-size: var(--step-1); color: var(--color-charcoal); max-width: 46ch; }
  .hero__actions { display: flex; gap: var(--space-2); margin-top: var(--space-3); flex-wrap: wrap; }

.hero__art { display: flex; justify-content: center; align-items: center; min-height: 420px; }
  .stat-cluster {
    position: relative;
    width: 320px;
    height: 420px;
  }
  .stat-chip {
    position: absolute;
    background: var(--color-navy);
    color: var(--color-white);
    border-radius: var(--radius);
    padding: 1.1em 1.4em;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    box-shadow: 0 16px 32px -12px rgba(27,58,99,0.4);
    animation: float 6s ease-in-out infinite;
  }
  .stat-chip__num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-3);
    color: var(--color-mustard-light);
    line-height: 1;
  }
  .stat-chip__label {
    font-size: var(--step--1);
    font-weight: 600;
    white-space: nowrap;
  }
  .stat-chip--a { top: 0; left: 0; animation-delay: 0s; }
  .stat-chip--b {
    top: 110px; right: 0;
    background: var(--color-mustard);
    color: var(--color-navy-deep);
    animation-delay: 0.6s;
  }
  .stat-chip--b .stat-chip__num { color: var(--color-navy-deep); }
  .stat-chip--c { top: 220px; left: 8%; animation-delay: 1.2s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .stat-chip { animation: none; }
  }

  .section__lede { max-width: 60ch; font-size: var(--step-1); margin-bottom: var(--space-4); }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .testimonial-heading { text-align: center; }
  .testimonial-heading .eyebrow {
    display: flex;
    width: 100%;
    justify-content: center;
  }
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius);
    padding: var(--space-3);
  }
  .testimonial-card__stars { color: var(--color-mustard-light); margin-bottom: 0.5em; font-size: var(--step--1); }
  .testimonial-card blockquote {
    margin: 0 0 0.6em;
    font-size: var(--step-0);
    color: var(--color-white);
    font-family: var(--font-body);
    font-weight: 400;
  }
  .testimonial-card__author { color: var(--color-mustard-light); font-weight: 700; margin: 0; }
  .testimonial-cta { text-align: center; margin-top: var(--space-4); }

  .cta-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__art { order: -1; }
    .why-grid { grid-template-columns: 1fr; }
    .testimonial-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .testimonial-grid { grid-template-columns: 1fr; }
  }
</style>