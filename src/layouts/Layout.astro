---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  canonicalOverride?: string;
  extraSchemaJson?: string;
}

const {
  title,
  description,
  path = '',
  ogImage,
  canonicalOverride,
  extraSchemaJson,
} = Astro.props;

const siteName = 'Mantra Academy';
const fullTitle = `${title} | ${siteName}`;
const SITE_URL = 'https://mantraacademy.example';
const canonicalURL = canonicalOverride || `${SITE_URL}${path}`;
const ogImageURL = ogImage ? (ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`) : `${SITE_URL}/images/og-cover.jpg`;

const allTestimonials = await getCollection('testimonials');
const reviewCount = allTestimonials.length;
const avgRating = reviewCount
  ? allTestimonials.reduce((sum, t) => sum + t.data.rating, 0) / reviewCount
  : null;

const schema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Mantra Academy",
  "description": "Maths, Science, SST and English tuition for Grades 7 to 10, covering CBSE and ICSE boards.",
  "url": SITE_URL,
  "telephone": "+91-93246-88372",
  "email": "learnwithusatmantra@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Ground Floor, Plot No. 199, Shakti Khand III, Indirapuram",
    "addressLocality": "Ghaziabad",
    "addressRegion": "Uttar Pradesh",
    "postalCode": "201010",
    "addressCountry": "IN"
  },
  "sameAs": [
    "https://www.instagram.com/learnwithmantra",
    "https://www.facebook.com/share/1CpeZgonLD/"
  ]
};

if (avgRating && reviewCount > 0) {
  schema.aggregateRating = {
    "@type": "AggregateRating",
    "ratingValue": avgRating.toFixed(1),
    "reviewCount": reviewCount,
  };
}

let extraSchema: unknown = null;
if (extraSchemaJson) {
  try {
    extraSchema = JSON.parse(extraSchemaJson);
  } catch {
    extraSchema = null;
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    {extraSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user) => {});
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    </script>
  </body>
</html>