---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand">Mantra Academy</p>
      <p class="footer-tagline">Strong foundations in Maths, Science, SST &amp; English, Grades 7–10, CBSE &amp; ICSE.</p>
    </div>

    <div>
      <h2 class="footer-heading">Contact</h2>
      <p>
          <a href="https://maps.app.goo.gl/ycRjhyuQ9EoyVZvEA">
            Ground Floor, Plot No. 199, Shakti Khand III,<br />
            Indirapuram, Ghaziabad, Uttar Pradesh 201010
          </a>
      </p>
      <p>
        <a href="tel:+919324688372">+91 93246 88372</a><br />
        <a href="mailto:learnwithusatmantra@gmail.com">learnwithusatmantra@gmail.com</a>
      </p>
    </div>

    <div>
      <h2 class="footer-heading">Follow</h2>
      <p class="footer-social">
        <a href="https://www.instagram.com/learnwithmantra" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1"/></svg>
        </a>
        <a href="https://www.facebook.com/share/1CpeZgonLD/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.5.3v2.7h-1.4c-1.4 0-1.8.8-1.8 1.7V12h3l-.5 2.9h-2.5v7A10 10 0 0 0 22 12Z"/></svg>
        </a>
      </p>
      <a class="btn btn--outline footer-cta" href="/admissions">Book a Free Demo Class</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} Mantra Academy. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy);
    color: var(--color-white);
    padding-top: var(--space-5);
  }
  .footer-social svg { display: block; }
  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    transition: background 0.18s ease;
  }
  .footer-social a:hover { background: var(--color-mustard); color: var(--color-navy-deep); }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
  }
  .footer-brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-2);
    margin-bottom: 0.3em;
  }
  .footer-tagline { color: rgba(255,255,255,0.8); }
  .footer-heading {
    color: var(--color-mustard-light);
    font-size: var(--step-0);
    margin-bottom: 0.6em;
  }
  .site-footer p { color: rgba(255,255,255,0.85); }
  .site-footer a { color: rgba(255,255,255,0.85); font-weight: 600; }
  .site-footer a:hover { color: var(--color-mustard-light); }
  .footer-social { display: flex; gap: var(--space-3); font-weight: 600; }
  .footer-cta { margin-top: var(--space-2); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-block: var(--space-2);
    font-size: var(--step--1);
    color: rgba(255,255,255,0.6);
    text-align: center;
  }
  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
