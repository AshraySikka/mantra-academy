---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand">Mantra Academy</p>
      <p class="footer-tagline">Strong foundations in Maths &amp; Science, Grades 7–10, CBSE &amp; ICSE.</p>
    </div>

    <div>
      <h2 class="footer-heading">Contact</h2>
      <p>
        Ground Floor, Plot No. 199, Shakti Khand III,<br />
        Indirapuram, Ghaziabad, Uttar Pradesh 201010
      </p>
      <p>
        <a href="tel:+919324688372">+91 93246 88372</a><br />
        <a href="mailto:learnwithusatmantra@gmail.com">learnwithusatmantra@gmail.com</a>
      </p>
    </div>

    <div>
      <h2 class="footer-heading">Follow</h2>
      <p class="footer-social">
        <a href="https://www.instagram.com/learnwithmantra" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.facebook.com/share/1CpeZgonLD/" target="_blank" rel="noopener noreferrer">Facebook</a>
      </p>
      <a class="btn btn--outline footer-cta" href="/admissions">Book a Free Demo Class</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} Mantra Academy. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy);
    color: var(--color-white);
    padding-top: var(--space-5);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
  }
  .footer-brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-2);
    margin-bottom: 0.3em;
  }
  .footer-tagline { color: rgba(255,255,255,0.8); }
  .footer-heading {
    color: var(--color-mustard-light);
    font-size: var(--step-0);
    margin-bottom: 0.6em;
  }
  .site-footer p { color: rgba(255,255,255,0.85); }
  .site-footer a { color: var(--color-white); }
  .site-footer a:hover { color: var(--color-mustard-light); }
  .footer-social { display: flex; gap: var(--space-3); font-weight: 600; }
  .footer-cta { margin-top: var(--space-2); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-block: var(--space-2);
    font-size: var(--step--1);
    color: rgba(255,255,255,0.6);
  }
  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
